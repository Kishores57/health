# ===========================
# Server Configuration
# ===========================
PORT=5000
NODE_ENV=development

# ===========================
# Database (MongoDB)
# ===========================
MONGO_URI=mongodb://127.0.0.1:27017/health-hub

# ===========================
# Authentication
# ===========================
JWT_SECRET=your_super_secret_jwt_key_here
SESSION_SECRET=your_session_secret_here

# ===========================
# Gmail OAuth2 (for booking & report emails)
# ===========================
EMAIL_USER=your_gmail@gmail.com
CLIENT_ID=your_google_oauth_client_id
CLIENT_SECRET=your_google_oauth_client_secret
REDIRECT_URI=https://developers.google.com/oauthplayground
REFRESH_TOKEN=your_refresh_token_from_oauth_playground


# ===========================
# Frontend URL (for CORS)
# set to your Vercel deployment URL in production
# ===========================
FRONTEND_URL=http://localhost:5000

# ===========================
# Frontend API URL (Vite build-time variable)
# In production: set to your Railway backend URL
# e.g. https://health-hub-backend.up.railway.app
# In development: leave empty (Vite proxy handles it)
# ===========================
VITE_API_URL=
