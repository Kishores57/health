# Environment Variables — Production Template
# Copy this file, fill in all values, and add them to your Railway dashboard
# under: Project → Settings → Variables
# DO NOT commit your real .env file — it is in .gitignore

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_strong_random_secret_min_32_chars
SESSION_SECRET=replace_with_another_strong_random_secret

# ── Owner Account ─────────────────────────────────────────────────────────────
# These are used to seed the single owner account on first startup
OWNER_USERNAME=owner
OWNER_PASSWORD=change_this_to_a_strong_password

# ── Cloudinary (Used for permanent PDF report storage) ───────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── EmailJS (Used for booking confirmations & report notifications) ───────────
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_TEMPLATE_BOOKING=your_booking_template_id
EMAILJS_TEMPLATE_REPORT=your_report_template_id

# ── URLs ──────────────────────────────────────────────────────────────────────
# Set this to your Railway app URL after deployment (e.g. https://yourapp.railway.app)
FRONTEND_URL=https://yourapp.railway.app
